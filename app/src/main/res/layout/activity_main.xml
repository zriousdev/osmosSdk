<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    tools:context=".MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Osmos Ads SDK"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Display Banner Ads &amp; Event Tracking"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Ad Container Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ad_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                app:cardBackgroundColor="@color/white">

                <FrameLayout
                    android:id="@+id/ad_render_area"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#F1F5F9"
                    android:gravity="center">

                    <!-- Fallback / Empty View -->
                    <LinearLayout
                        android:id="@+id/layout_fallback"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/img_fallback_icon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/stat_notify_error"
                            android:contentDescription="Ad Error Icon"
                            app:tint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_fallback_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No ad loaded. Tap Load Ad."
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- Banner ImageView -->
                    <ImageView
                        android:id="@+id/iv_ad_banner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:visibility="gone"
                        android:contentDescription="Osmos Banner Ad" />

                    <!-- Loading Progress -->
                    <ProgressBar
                        android:id="@+id/progress_bar_ad"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@color/primary" />

                    <!-- 50% Visible Overlay indicator (green label overlay) -->
                    <LinearLayout
                        android:id="@+id/layout_impression_overlay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top"
                        android:background="#D1FAE5"
                        android:orientation="horizontal"
                        android:padding="6dp"
                        android:gravity="center"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓ 50% Visible - Impression Registered"
                            android:textColor="#065F46"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Control Buttons Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btn_load_ad"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:text="Load Ad"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="12dp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn_clear_logs"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="54dp"
                        android:text="Clear Logs"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="2dp"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Event Console Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_light"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SDK Event Console"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp" />

                    <!-- Monospace scrolling terminal view -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:background="@color/console_bg"
                        android:padding="12dp"
                        android:scrollbarThumbVertical="@android:color/darker_gray">

                        <TextView
                            android:id="@+id/tv_console_logs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textColor="@color/console_text_log"
                            android:textSize="12sp"
                            android:text="Console initialized...\nWaiting for events..."
                            android:lineSpacingExtra="4dp" />
                    </ScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
